# Server
PORT=5000
NODE_ENV=development

# Database (Postgres connection string, e.g. from Neon/Supabase/Render)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/gearup_db?schema=public"

# JWT
JWT_ACCESS_SECRET=super-secret-access-key-change-me
JWT_REFRESH_SECRET=super-secret-refresh-key-change-me
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d

# Admin seed credentials (used by prisma/seed.ts)
ADMIN_EMAIL=admin@gearup.com
ADMIN_PASSWORD=Admin123!
ADMIN_NAME="GearUp Admin"

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx
CLIENT_SUCCESS_URL=http://localhost:5000/api/payments/success
CLIENT_CANCEL_URL=http://localhost:5000/api/payments/cancel

# CORS
CORS_ORIGIN=*
