{
  "info": {
    "name": "GearUp API",
    "description": "Rent Sports & Outdoor Gear Instantly - Assignment 4 (GearUp variant)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "adminToken", "value": "" },
    { "key": "providerToken", "value": "" },
    { "key": "customerToken", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "gearId", "value": "" },
    { "key": "rentalOrderId", "value": "" },
    { "key": "paymentId", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sam Customer\",\n  \"email\": \"customer1@example.com\",\n  \"password\": \"Customer123!\",\n  \"phone\": \"01700000000\",\n  \"role\": \"CUSTOMER\"\n}"
            }
          }
        },
        {
          "name": "Register Provider",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Trailblazer Rentals\",\n  \"email\": \"provider1@example.com\",\n  \"password\": \"Provider123!\",\n  \"phone\": \"01800000000\",\n  \"role\": \"PROVIDER\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@gearup.com\",\n  \"password\": \"Customer123!\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Create Category (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/categories",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Cycling\",\n  \"description\": \"Bikes and cycling accessories\"\n}"
            }
          }
        },
        { "name": "Get All Categories", "request": { "method": "GET", "url": "{{baseUrl}}/categories" } },
        { "name": "Get Category By Id", "request": { "method": "GET", "url": "{{baseUrl}}/categories/{{categoryId}}" } },
        {
          "name": "Update Category (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/categories/{{categoryId}}",
            "body": { "mode": "raw", "raw": "{\n  \"description\": \"Updated description\"\n}" }
          }
        },
        {
          "name": "Delete Category (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/categories/{{categoryId}}"
          }
        }
      ]
    },
    {
      "name": "Gear (Public)",
      "item": [
        {
          "name": "Browse Gear (filters + pagination)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/gear?search=bike&minPrice=5&maxPrice=50&page=1&limit=10"
          }
        },
        { "name": "Get Gear By Id", "request": { "method": "GET", "url": "{{baseUrl}}/gear/{{gearId}}" } }
      ]
    },
    {
      "name": "Provider",
      "item": [
        {
          "name": "Add Gear Item",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{providerToken}}" }
            ],
            "url": "{{baseUrl}}/provider/gear",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Mountain Bike - Trek Marlin 7\",\n  \"description\": \"A reliable hardtail mountain bike, great for trails and city rides.\",\n  \"brand\": \"Trek\",\n  \"pricePerDay\": 15,\n  \"quantityTotal\": 5,\n  \"images\": [],\n  \"categoryId\": \"{{categoryId}}\"\n}"
            }
          }
        },
        {
          "name": "Get My Inventory",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{providerToken}}" }],
            "url": "{{baseUrl}}/provider/gear"
          }
        },
        {
          "name": "Update Gear Item",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{providerToken}}" }
            ],
            "url": "{{baseUrl}}/provider/gear/{{gearId}}",
            "body": { "mode": "raw", "raw": "{\n  \"pricePerDay\": 18\n}" }
          }
        },
        {
          "name": "Delete Gear Item",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{providerToken}}" }],
            "url": "{{baseUrl}}/provider/gear/{{gearId}}"
          }
        },
        {
          "name": "Get Incoming Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{providerToken}}" }],
            "url": "{{baseUrl}}/provider/orders"
          }
        },
        {
          "name": "Update Order Status (confirm/cancel/pickup/return)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{providerToken}}" }
            ],
            "url": "{{baseUrl}}/provider/orders/{{rentalOrderId}}",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"CONFIRMED\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Rentals",
      "item": [
        {
          "name": "Create Rental Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": "{{baseUrl}}/rentals",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"startDate\": \"2026-08-01\",\n  \"endDate\": \"2026-08-05\",\n  \"items\": [\n    { \"gearItemId\": \"{{gearId}}\", \"quantity\": 1 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Get My Rental Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/rentals"
          }
        },
        {
          "name": "Get Rental Order By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/rentals/{{rentalOrderId}}"
          }
        },
        {
          "name": "Cancel Rental Order",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/rentals/{{rentalOrderId}}/cancel"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment Session (Stripe Checkout)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": "{{baseUrl}}/payments/create",
            "body": { "mode": "raw", "raw": "{\n  \"rentalOrderId\": \"{{rentalOrderId}}\"\n}" }
          }
        },
        {
          "name": "Confirm Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": "{{baseUrl}}/payments/confirm",
            "body": { "mode": "raw", "raw": "{\n  \"sessionId\": \"cs_test_xxxxxxxxxxxxx\"\n}" }
          }
        },
        {
          "name": "Get My Payment History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/payments"
          }
        },
        {
          "name": "Get Payment By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/payments/{{paymentId}}"
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Create Review (after RETURNED rental)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": "{{baseUrl}}/reviews",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gearItemId\": \"{{gearId}}\",\n  \"rating\": 5,\n  \"comment\": \"Great gear, smooth ride!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/users"
          }
        },
        {
          "name": "Update User Status (suspend/activate)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/admin/users/{{userId}}",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"SUSPENDED\"\n}" }
          }
        },
        {
          "name": "Get All Gear (Admin oversight)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/gear"
          }
        },
        {
          "name": "Get All Rentals (Admin oversight)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/rentals"
          }
        }
      ]
    }
  ]
}
